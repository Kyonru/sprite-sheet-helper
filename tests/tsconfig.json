{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "types": ["node", "vitest"],
    "baseUrl": "..",
    "paths": {
      "@kyonru/zustand-inspector": [
        "./packages/zustand-inspector/src"
      ],
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "./**/*.ts",
    "../src/**/*.ts",
    "../src/**/*.tsx",
    "../packages/zustand-inspector/src/**/*.ts"
  ]
}
